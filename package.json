{
  "name": "market-watcher",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "coverage:open": "open packages/valuation-engine/coverage/html/index.html",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "turbo": "^2.9.6",
    "typescript": "^6"
  }
}
