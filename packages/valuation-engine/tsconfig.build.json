{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "module": "ESNext"
  },
  "include": ["src/**/*"],
  "exclude": ["tests/**/*", "dist"]
}
